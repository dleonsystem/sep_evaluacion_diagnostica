Function ExtraerCorreo(texto As String) As String
    Dim regex As Object, coincidencias As Object
    Set regex = CreateObject("VBScript.RegExp")
    regex.Pattern = "[A-Z0-9._%+-]+@[A-Z0-9.-]+\.[A-Z]{2,}"
    regex.Global = True
    regex.IgnoreCase = True

    If regex.Test(texto) Then
        Set coincidencias = regex.Execute(texto)
        ExtraerCorreo = coincidencias(0)
    Else
        ExtraerCorreo = "No encontrado"
    End If
End Function
Function ExtraerID(texto As String) As String
    Dim inicioID As Long
    Dim finID As Long
    Dim resultado As String

    ' Buscar la posición de "ID:"
    inicioID = InStr(1, texto, "ID:", vbTextCompare)

    If inicioID > 0 Then
        ' Buscar la posición del siguiente "|"
        finID = InStr(inicioID + 3, texto, "|")

        If finID > 0 Then
            ' Extraer el texto entre "ID:" y "|"
            resultado = Mid(texto, inicioID + 3, finID - (inicioID + 3))
            ExtraerID = Trim(resultado)
        Else
            ExtraerID = "Delimitador '|' no encontrado"
        End If
    Else
        ExtraerID = "ID: no encontrado"
    End If
End Function


Function ContieneFecha(col As Collection, valor As String) As Boolean
    Dim item As Variant
    ContieneFecha = False
    For Each item In col
        If item = valor Then
            ContieneFecha = True
            Exit Function
        End If
    Next item
End Function

