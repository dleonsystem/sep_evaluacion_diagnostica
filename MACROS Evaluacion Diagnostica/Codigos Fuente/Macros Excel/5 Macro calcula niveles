Function ObtenerLibroAbierto(nombreLibro As String) As Workbook
    Dim wb As Workbook
    For Each wb In Application.Workbooks
        If wb.Name = nombreLibro Then
            Set ObtenerLibroAbierto = wb
            Exit Function
        End If
    Next wb
    Set ObtenerLibroAbierto = Nothing
End Function
 Function BuscarColumnaPorEncabezado(ws As Worksheet, nombreEncabezado As String) As Long
    Dim c As Range
    For Each c In ws.Rows(1).Cells
        If Trim(UCase(c.Value)) = UCase(nombreEncabezado) Then
            BuscarColumnaPorEncabezado = c.Column
            Exit Function
        End If
    Next c
    BuscarColumnaPorEncabezado = 0 ' No encontrado
End Function
