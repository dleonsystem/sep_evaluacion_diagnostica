Sub Reemplazar7PorVacioEnRango(wbBase As Workbook)
    Dim ws As Worksheet
    Dim fila As Long, col As Long
    Dim ultimaFila As Long

    For Each ws In wbBase.Worksheets
        ' Determinar la última fila con datos en la hoja (puedes ajustar si quieres buscar en otra columna)
        ultimaFila = ws.Cells(ws.Rows.Count, 14).End(xlUp).Row

        ' Recorrer filas desde la 2 hasta la última
        For fila = 2 To ultimaFila
            ' Recorrer columnas desde la 14 (columna N) hasta la columna AR
            For col = 14 To ws.Range("AR1").Column
                With ws.Cells(fila, col)
                    If .Value = 7 Then .Value = " "
                End With
            Next col
        Next fila
    Next ws

    'MsgBox "Reemplazo de '7' completado en todas las hojas del libro.", vbInformation
End Sub

