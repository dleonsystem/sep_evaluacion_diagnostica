Sub ContarCCTTurnoNivel()

    Dim fso As Object, carpeta As Object, archivo As Object
    Dim wbOrigen As Workbook, wbDestino As Workbook
    Dim wsOrigen As Worksheet, wsDestino As Worksheet
    Dim hojaNombre As Variant
    Dim j As Long, lastRow As Long
    Dim cct As String, turno As String, nivel As String
    Dim clave As Variant
    Dim filaDestino As Long
    Dim rutaCarpeta As String, rutaPlantilla As String, rutaFinal As String
    Dim dictUnicos As Object
    Dim fechaTexto As String, horaTexto As String, nombreFinal As String

    ' Rutas
    'rutaCarpeta = "\\10.3.10.146\Resultados\Compartido\"
     rutaCarpeta = "C:\RECIBE_SiCRER.25_26.SEPT1\COMPRIMIDOS\"
    rutaPlantilla = "C:\Reportes\ESTADISTICA NACIONAL ACTUALIZADA.xlsx"
    fechaTexto = Format(Date, "yyyymmdd")
    horaTexto = Format(Time, "hhmm")
    nombreFinal = "ESTADISTICA NACIONAL ACTUALIZADA_" & fechaTexto & "_" & horaTexto & ".xlsx"
    rutaFinal = "C:\Reportes\" & nombreFinal

    ' Diccionario para evitar duplicados
    Set dictUnicos = CreateObject("Scripting.Dictionary")

    ' Abrir plantilla limpia
    Set wbDestino = Workbooks.Open(rutaPlantilla)

    ' Crear o limpiar hoja Conteo
    On Error Resume Next
    Set wsDestino = wbDestino.Sheets("Conteo")
    If wsDestino Is Nothing Then
        Set wsDestino = wbDestino.Sheets.Add
        wsDestino.Name = "Conteo"
    Else
        wsDestino.Cells.Clear
    End If
    On Error GoTo 0

    ' Encabezados
    wsDestino.Cells(1, 1).Value = "cct"
    wsDestino.Cells(1, 2).Value = "turno"
    wsDestino.Cells(1, 3).Value = "nivel"
    filaDestino = 2

    ' Hojas a procesar
    Dim hojas() As Variant
    hojas = Array("PRE3", "PRI1", "PRI2", "PRI3", "PRI4", "PRI5", "PRI6", "SEC1", "SEC2", "SEC3", "SEC4", "SEC5", "SEC6")

    ' Recorre todos los archivos en la carpeta
    Set fso = CreateObject("Scripting.FileSystemObject")
    Set carpeta = fso.GetFolder(rutaCarpeta)

    For Each archivo In carpeta.Files
        If LCase(fso.GetExtensionName(archivo.Name)) Like "xls*" Then
            Set wbOrigen = Workbooks.Open(archivo.Path)

            For Each hojaNombre In hojas
                On Error Resume Next
                Set wsOrigen = wbOrigen.Sheets(hojaNombre)
                On Error GoTo 0

                If Not wsOrigen Is Nothing Then
                    lastRow = wsOrigen.Cells(wsOrigen.Rows.Count, "A").End(xlUp).Row

                    For j = 2 To lastRow
                        cct = UCase(Trim(wsOrigen.Cells(j, 1).Value))
                        turno = UCase(Trim(wsOrigen.Cells(j, 2).Value))
                        nivel = UCase(Trim(wsOrigen.Cells(j, 4).Value))

                        If cct <> "" And turno <> "" And nivel <> "" Then
                            clave = cct & "|" & turno & "|" & nivel
                            If Not dictUnicos.Exists(clave) Then
                                dictUnicos.Add clave, Array(cct, turno, nivel)
                            End If
                        End If
                    Next j
                End If
                Set wsOrigen = Nothing
            Next hojaNombre

            wbOrigen.Close SaveChanges:=False
        End If
    Next archivo

    ' Escribir resultados únicos
    'Dim item As Variant
    'For Each clave In dictUnicos.Keys
    '    item = dictUnicos(clave)
    '    wsDestino.Cells(filaDestino, 1).Value = item(0)
    '    wsDestino.Cells(filaDestino, 2).Value = item(1)
    '    wsDestino.Cells(filaDestino, 3).Value = item(2)
    '    filaDestino = filaDestino + 1
    'Next clave
    
    ' Escribir resultados únicos en un solo paso
Dim arrDatos() As Variant
Dim i As Long

ReDim arrDatos(1 To dictUnicos.Count, 1 To 3)

i = 1
For Each clave In dictUnicos.Keys
    arrDatos(i, 1) = dictUnicos(clave)(0)
    arrDatos(i, 2) = dictUnicos(clave)(1)
    arrDatos(i, 3) = dictUnicos(clave)(2)
    i = i + 1
Next clave

' Volcar todo el arreglo a la hoja de una sola vez
wsDestino.Range("A2").Resize(dictUnicos.Count, 3).Value = arrDatos

    
'------------------------------------------------------------------------------------------------------------------

    Sheets("Conteo").Select
    Set wsDestino = wbDestino.Sheets("Conteo")
    lastRow = wsDestino.Cells(wsDestino.Rows.Count, "A").End(xlUp).Row

    Range("D1").Select
    ActiveCell.FormulaR1C1 = "ident"
    Range("E1").Select
    ActiveCell.FormulaR1C1 = "muestra"
    
    Range("D2").Select
    ActiveCell.FormulaR1C1 = "=TEXT(VALUE(MID(RC[-3],1,2)),""##"")"
    Selection.AutoFill Destination:=Range("D2:D" + CStr(lastRow))
    
    Range("E2").Select
    ActiveCell.FormulaR1C1 = _
        "=XLOOKUP(CONCAT(RC[-4],RC[-3]),Aux!C[-4],Aux!C,0,0,1)"
    Selection.AutoFill Destination:=Range("E2:E" + CStr(lastRow))
    
    Sheets("Hoja1").Select
    Cells.Select
    Selection.Copy
    Selection.PasteSpecial Paste:=xlPasteValues, Operation:=xlNone, SkipBlanks _
        :=False, Transpose:=False
    Application.CutCopyMode = False
    Range("K1").Select

    Sheets("Conteo").Select
    Cells.Select
    Selection.Copy
    Selection.PasteSpecial Paste:=xlPasteValues, Operation:=xlNone, SkipBlanks _
        :=False, Transpose:=False
    Application.CutCopyMode = False
    Range("K1").Select


    Sheets("Hoja1").Select

    hojasOcultas = Array("Conteo", "Aux")

    ' Recorrer el arreglo y ocultar cada hoja
    For Each nombreHoja In hojasOcultas
        Sheets(nombreHoja).Visible = xlSheetVeryHidden
    Next nombreHoja



'---------------------------------------------------------------------------------------------------------------------
    
    
    

    ' Guardar como nuevo archivo con fecha y hora
    Application.DisplayAlerts = False
    wbDestino.SaveAs rutaFinal
    wbDestino.Close SaveChanges:=False
    Application.DisplayAlerts = True

    'MsgBox "? Archivo generado: " & nombreFinal

End Sub

