# Set default behavior to handle line endings automatically.
* text=auto eol=lf

# Force bash scripts to always use LF.
*.sh text eol=lf

# Explicitly set line endings for typical source files.
*.js text eol=lf
*.ts text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sql text eol=lf
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
