# Configuración de Base de Datos
DB_USER=postgres
DB_PASSWORD=secretpassword
DB_NAME=eia_db
DB_PORT=5432

# Seguridad
JWT_SECRET=  # (Requerido) MÃ­nimo 32 caracteres; no usar valores por defecto en producciÃ³n
CORS_ORIGIN=http://localhost:4200,https://app.sep.gob.mx  # (Requerido en Prod) Lista separada por comas

# SFTP (Valores por defecto para Docker Compose)
SFTP_HOST=sftp
SFTP_PORT=22
SFTP_USER=eia_user
SFTP_PASSWORD=CHANGE_ME_STRONG_PASSWORD
SFTP_BASE_PATH=/home/eia_user/upload
SFTP_USERS=eia_user:CHANGE_ME_STRONG_PASSWORD:1001

# Email (Opcional para desarrollo)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=user@gmail.com
SMTP_PASS=app_password

# El puerto 4000 es el estándar de Apollo Server en el contenedor
PORT=4000
