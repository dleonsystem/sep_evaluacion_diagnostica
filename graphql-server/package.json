{
  "name": "graphql-server-eia",
  "version": "1.0.0",
  "description": "Servidor GraphQL para la plataforma de Evaluación Integral de Aprendizaje (EIA) - SEP",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node dist/index.js",
    "build": "node node_modules/typescript/bin/tsc",
    "start": "node dist/index.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "db:init": "psql -U postgres -f scripts/init-db.sql",
    "db:seed": "psql -U postgres -d eia_db -f scripts/seed-data.sql",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "graphql",
    "apollo-server",
    "postgresql",
    "typescript",
    "sep",
    "eia",
    "psp",
    "rup",
    "cmmi"
  ],
  "author": "SEP - Evaluación Diagnóstica",
  "license": "MIT",
  "dependencies": {
    "@apollo/server": "^4.10.0",
    "graphql": "^16.8.1",
    "pg": "^8.11.3",
    "dotenv": "^16.4.1",
    "winston": "^3.11.0",
    "class-validator": "^0.14.1",
    "reflect-metadata": "^0.2.1",
    "dataloader": "^2.2.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "compression": "^1.7.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/pg": "^8.11.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/compression": "^1.7.5",
    "@types/jest": "^29.5.11",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "prettier": "^3.2.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
