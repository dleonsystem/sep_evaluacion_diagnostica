# Server Configuration
NODE_ENV=development
PORT=4000
HOST=localhost

# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=eia_db
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_POOL_MIN=2
DB_POOL_MAX=10

# GraphQL Configuration
GRAPHQL_PATH=/graphql
GRAPHQL_INTROSPECTION=true
GRAPHQL_PLAYGROUND=true

# Security
CORS_ORIGIN=http://localhost:4200
JWT_SECRET=  # (Requerido) Generar una clave fuerte de al menos 32 caracteres (Ej: openssl rand -base64 32)
JWT_EXPIRATION=24h

# Logging
LOG_LEVEL=debug
LOG_FILE_PATH=./logs/app.log

# PSP Metrics (Personal Software Process)
PSP_METRICS_ENABLED=true
PSP_TIME_TRACKING=true

# AI Collaboration Settings
AI_COLLABORATION_MODE=true
AI_DOCUMENTATION_AUTO_UPDATE=true

# SFTP Configuration
SFTP_HOST=localhost
SFTP_PORT=2222
SFTP_USER=user
SFTP_PASSWORD=pass

# SMTP Configuration
SMTP_TEST_MODE=false
SMTP_SERVICE=gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_NAME=Sistema SiCRER
SMTP_FROM_EMAIL=no-reply@sicrer.sep.gob.mx

# Application URL
APP_URL=http://localhost:4200
