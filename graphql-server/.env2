# Server Configuration
NODE_ENV=development
PORT=4000
HOST=10.3.10.57

# PostgreSQL Database Configuration
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=eia_db
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_POOL_MIN=2
DB_POOL_MAX=10
PGSSLMODE=disable

# GraphQL Configuration
GRAPHQL_PATH=/graphql
GRAPHQL_INTROSPECTION=true
GRAPHQL_PLAYGROUND=true

# Security
CORS_ORIGIN=*
JWT_SECRET=your_secure_password
JWT_EXPIRATION=24h

# Logging
LOG_LEVEL=debug
LOG_FILE_PATH=./logs/app.log

# PSP Metrics (Personal Software Process)
PSP_METRICS_ENABLED=true
PSP_TIME_TRACKING=true

# AI Collaboration Settings
AI_COLLABORATION_MODE=true
AI_DOCUMENTATION_AUTO_UPDATE=true

# SFTP Configuration
SFTP_HOST=10.3.10.57
SFTP_PORT=2222
SFTP_USER=user
SFTP_PASSWORD=pass
